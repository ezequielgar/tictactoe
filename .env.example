# ===== DATABASE =====
DB_USER=ttt_user
DB_PASSWORD=cambia_esta_password_segura
DB_NAME=tictactoe_db

# ===== JWT =====
JWT_SECRET=genera_un_string_aleatorio_muy_largo_aqui
JWT_REFRESH_SECRET=otro_string_aleatorio_diferente

# ===== GOOGLE OAUTH =====
# Obtener en: https://console.cloud.google.com
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# Producción:
GOOGLE_CALLBACK_URL=https://tictactoe.lechugasweb.com.ar/api/auth/google/callback
# Desarrollo local:
# GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ===== URLS =====
# Producción:
FRONTEND_URL=https://tictactoe.lechugasweb.com.ar
# Desarrollo local:
# FRONTEND_URL=http://localhost:3000

# ===== FRONTEND (Vite) =====
# Producción:
VITE_API_URL=https://tictactoe.lechugasweb.com.ar/api
# Desarrollo local:
# VITE_API_URL=http://localhost:4000/api

# ===== MISC =====
NODE_ENV=development
PORT=4000
